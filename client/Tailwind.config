/** @type {import('tailwindcss').Config} */
export default {
  content: ['./index.html', './src/**/*.{js,jsx}'],
  theme: {
    extend: {
      fontFamily: {
        sans: ['Plus Jakarta Sans', 'sans-serif'],
        display: ['Outfit', 'sans-serif'],
      },
      colors: {
        brand: {
          50:  '#eff6ff',
          100: '#dbeafe',
          200: '#bfdbfe',
          300: '#93c5fd',
          400: '#60a5fa',
          500: '#3b82f6',
          600: '#2563eb',
          700: '#1d4ed8',
        },
        sky: {
          soft: '#f0f7ff',
          mist: '#e8f2ff',
          card: '#f7faff',
        }
      },
      boxShadow: {
        'card':    '0 4px 24px rgba(59,130,246,0.08)',
        'card-md': '0 8px 40px rgba(59,130,246,0.12)',
        'card-lg': '0 16px 60px rgba(59,130,246,0.16)',
        'btn':     '0 4px 14px rgba(37,99,235,0.35)',
        'float':   '0 20px 60px rgba(59,130,246,0.18)',
      },
      borderRadius: {
        '2xl': '1rem',
        '3xl': '1.5rem',
        '4xl': '2rem',
      },
      animation: {
        'float-slow':  'floatSlow 6s ease-in-out infinite',
        'float-med':   'floatSlow 4s ease-in-out infinite 1s',
        'float-fast':  'floatSlow 3.5s ease-in-out infinite 0.5s',
        'fade-in-up':  'fadeInUp 0.7s ease forwards',
        'pulse-dot':   'pulseDot 2s ease-in-out infinite',
        'spin-slow':   'spin 12s linear infinite',
        'scan':        'scanLine 3s linear infinite',
        'counter':     'counterUp 0.5s ease forwards',
        'slide-in':    'slideIn 0.6s ease forwards',
      },
      keyframes: {
        floatSlow: {
          '0%,100%': { transform: 'translateY(0px)' },
          '50%':     { transform: 'translateY(-12px)' },
        },
        fadeInUp: {
          '0%':   { opacity: '0', transform: 'translateY(28px)' },
          '100%': { opacity: '1', transform: 'translateY(0)' },
        },
        pulseDot: {
          '0%,100%': { transform: 'scale(1)', opacity: '1' },
          '50%':     { transform: 'scale(1.5)', opacity: '0.6' },
        },
        scanLine: {
          '0%':   { transform: 'translateY(-100%)' },
          '100%': { transform: 'translateY(500%)' },
        },
        slideIn: {
          '0%':   { opacity: '0', transform: 'translateX(-20px)' },
          '100%': { opacity: '1', transform: 'translateX(0)' },
        },
      },
    },
  },
  plugins: [],
}